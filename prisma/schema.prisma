generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model instructions {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id  String?   @db.Uuid
  name        String?
  instruction String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @db.Timestamptz(6)
}

model log {
  id          Int       @id @default(autoincrement())
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  event       String?   @db.VarChar(50)
  name        String?   @db.VarChar(50)
  run_id      String?   @db.VarChar(50)
  tags        String?   @db.VarChar(50)
  metadata    String?
  data        String?
  all_content String?
}

model log_cada_chunk {
  id                Int       @id @default(autoincrement())
  chunk             String?   @db.VarChar(1024)
  iteration         Int?
  thread_id         String?   @db.Uuid
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  content           String?   @db.VarChar(255)
  args              String?   @db.VarChar(255)
  response_metadata String?   @db.VarChar(255)
}

model log_geral {
  id         Int       @id @default(autoincrement())
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  text       String?
}

model log_uso {
  id               Int       @id @default(autoincrement())
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  type             String?   @db.VarChar(50)
  text             String?
  time_elapsed_sec Decimal?  @db.Decimal(15, 3)
  thread_id        String?   @db.Uuid
}

model profiles {
  id                  String       @id(map: "profiles_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  apikey              String?      @unique(map: "profiles_apikey_idx") @db.VarChar
  name                String?      @db.VarChar
  system_prompt       String?      @db.VarChar
  system_prompt_teste String?      @db.VarChar
  db_schema           String?      @db.VarChar
  created_at          DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?    @db.Timestamptz(6)
  default_db          String?      @db.VarChar
  connection_id       Int?
  modelo_id           Int?
  connections         connections? @relation(fields: [connection_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "profiles_connections_fk")
  modelos             modelos?     @relation(fields: [modelo_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "profiles_modelos_fk")
}

model thread_messages {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  thread_id         String?   @db.Uuid
  role              String?   @db.VarChar(50)
  content           String?
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @db.Timestamptz(6)
  user_id           String?   @db.VarChar(50)
  access_profile_id String?   @db.VarChar(50)
}

model threads {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id        String?   @db.Uuid
  title             String?   @db.VarChar(50)
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @db.Timestamptz(6)
  user_id           String?   @db.VarChar(50)
  access_profile_id String?   @db.VarChar(50)
}

model sec_refresh_token {
  id        Int        @id(map: "newtable_pk_1") @default(autoincrement())
  token     String?    @db.VarChar
  user_id   Int?
  sec_users sec_users? @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "sec_refresh_token_sec_users_fk")
}

model sec_users {
  id                Int                 @id(map: "newtable_pk") @default(autoincrement())
  pswd              String?             @db.VarChar
  name              String?             @db.VarChar
  email             String?             @unique(map: "newtable_unique") @db.VarChar
  sec_refresh_token sec_refresh_token[]
}

model sec_log {
  id         Int       @id(map: "log_geral_pkey_1") @default(autoincrement())
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  user       String?
  url        String?   @db.VarChar
  method     String?   @db.VarChar
  body       String?   @db.VarChar
  params     String?   @db.VarChar
  ip         String?   @db.VarChar
  remarks    String?   @db.VarChar
}

model connections {
  id          Int        @id(map: "connections_pk") @default(autoincrement())
  env_name    String?    @db.VarChar
  description String?    @db.VarChar
  created_at  DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?  @db.Timestamptz(6)
  profiles    profiles[]
}

model modelos {
  id          Int        @id(map: "connections_pk_1") @default(autoincrement())
  name        String?    @db.VarChar
  description String?    @db.VarChar
  created_at  DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?  @db.Timestamptz(6)
  profiles    profiles[]
}
